---
import TahiraLayout from "../../layouts/Tahira/TahiraLayout.astro";
---

<TahiraLayout>
  <div class="flex flex-col w-full mb-8">
    <div>
      <h2 class="text-3xl text-center my-8">Walkthrough</h2>
    </div>

    <div class="tabs-nav flex flex-col sm:flex-row gap-4 mb-8" role="tablist">
      <button
        class="tab-button active"
        id="catholic-tab"
        data-tab="catholic"
        type="button"
        role="tab"
        aria-controls="catholic"
        aria-selected="true">Catholic Church</button
      >
      <button
        class="tab-button"
        id="orthodox-tab"
        data-tab="orthodox"
        type="button"
        role="tab"
        aria-controls="orthodox"
        aria-selected="false">Orthodox Church</button
      >
      <button
        class="tab-button"
        id="armenian-tab"
        data-tab="armenian"
        type="button"
        role="tab"
        aria-controls="armenian"
        aria-selected="false">Armenian Church</button
      >
    </div>
    <div class="tab-content">
      <div
        class="tab-panel active"
        id="catholic"
        role="tabpanel"
        aria-labelledby="catholic-tab"
      >
        <div class="flex flex-col items-center">
          <iframe
            class="panorama"
            src="https://www.theasys.io/viewer/dC5F12cx9lhrvTmtYKzOu53nJo38pg"
            allowfullscreen="true"
            frameborder="0"
            scrolling="no"
            allow="vr;gyroscope;accelerometer"
            style="border:none;"></iframe>
        </div>
      </div>
      <div
        class="tab-panel"
        id="orthodox"
        role="tabpanel"
        aria-labelledby="orthodox-tab"
      >
        <div class="flex flex-col items-center">
          <iframe
            class="panorama"
            src="https://www.theasys.io/viewer/tDzlAVq8bPx3LRXLJLAmLXrU8mLD9N"
            allowfullscreen="true"
            frameborder="0"
            scrolling="no"
            allow="vr;gyroscope;accelerometer"
            style="border:none;"></iframe>
        </div>
      </div>
      <div
        class="tab-panel"
        id="armenian"
        role="tabpanel"
        aria-labelledby="armenian-tab"
      >
        <div class="flex flex-col items-center">
          <iframe
            class="panorama"
            src="https://www.theasys.io/viewer/9Skq4fGazKh0Q9oA68Lj2sIZFgfckz"
            allowfullscreen="true"
            frameborder="0"
            scrolling="no"
            allow="vr;gyroscope;accelerometer"
            style="border:none;"></iframe>
        </div>
      </div>
    </div>
  </div>

  <style>
    .tab-button {
      flex: 1;
      padding: 12px 24px;
      font-size: 16px;
      font-weight: 500;
      color: #9e9d9b;
      background-color: transparent;
      border: 1px solid #2a2929;
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .tab-button:hover {
      color: #121212;
      background-color: #dbd8ce;
    }

    .tab-button.active {
      color: #eceae4;
      background-color: #121212;
      border-color: #121212;
    }

    .tab-panel {
      display: none;
      transition: all;
    }

    .tab-panel.active {
      display: block;
    }

    .panorama {
      width: 300px;
      height: 225px;
    }

    @media (min-width: 420px) {
      .panorama {
        width: 400px;
        height: 300px;
      }
    }

    @media (min-width: 640px) {
      .panorama {
        width: 600px;
        height: 450px;
      }
    }

    @media (min-width: 768px) {
      .panorama {
        width: 700px;
        height: 525px;
      }
    }

    @media (min-width: 1024px) {
      .panorama {
        width: 800px;
        height: 600px;
      }
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tabButtons = document.querySelectorAll('.tab-button');
      const tabPanels = document.querySelectorAll('.tab-panel');

      tabButtons.forEach(button => {
        button.addEventListener('click', () => {
          const targetTab = button.getAttribute('data-tab')!;

          // Remove active class from all buttons and panels
          tabButtons.forEach(btn => {
            btn.classList.remove('active');
            btn.setAttribute('aria-selected', 'false');
          });
          tabPanels.forEach(panel => {
            panel.classList.remove('active');
          });

          // Add active class to clicked button and corresponding panel
          button.classList.add('active');
          button.setAttribute('aria-selected', 'true');
          document.getElementById(targetTab)?.classList.add('active');
        });
      });
    });
  </script>
</TahiraLayout>
