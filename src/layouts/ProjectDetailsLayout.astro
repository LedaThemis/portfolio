---
import Layout from "./Layout.astro";
import Contact from "../components/Contact.astro";
import ProjectLinks from "../components/ProjectDetail/ProjectLinks.astro";
import ProjectTechnologies from "../components/ProjectDetail/ProjectTechnologies.astro";
import ProjectHeader from "../components/ProjectDetail/ProjectHeader.astro";
import type { ProjectDetailsProps } from "../lib/interfaces/ProjectDetails";
import LayoutMinimal from "./LayoutMinimal.astro";

const { frontmatter } = Astro.props;

type Props = ProjectDetailsProps;

const pageTitle = `${frontmatter.projectName} — Adil Al Qaba`;
const pageDesc = `Details on the implementation, the why behind and technologies of ${frontmatter.projectName} by Adil Al Qaba`;
---

<LayoutMinimal title={pageTitle} description={pageDesc}>
  <main>
    <article>
      <ProjectHeader
        name={frontmatter.projectName}
        description={frontmatter.projectDescription}
      />
      <ProjectTechnologies technologies={frontmatter.projectTechnologies} />
      <ProjectLinks
        name={frontmatter.projectName}
        source={frontmatter.projectSource}
        demo={frontmatter.projectDemo}
      />
      <div>
        <slot />
      </div>
    </article>
    <Contact />
  </main>
</Layout>
