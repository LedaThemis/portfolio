---
// Shared styles
import "../styles/minimal.css";

// Components
import FooterMinimal from "../components/FooterMinimal.astro";
import NavbarMinimal from "../components/NavbarMinimal.astro";

// Vercel
import SpeedInsights from "@vercel/speed-insights/astro";

export interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.ico" /><link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/apple-touch-icon.png"
    />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:image" content="https://res.cloudinary.com/dj08db9y2/image/upload/f_auto/q_auto/c_fit,w_1080/opengraph" />
    <title>{title}</title>
    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Adil Al Qaba",
        "givenName": "Adil",
        "familyName": "Al Qaba",
        "alternateName": "عادل محمد عدنان",
        "email": "contact@leda.dev",
        "jobTitle": "Software Engineer",
        "url": "https://www.alqaba.com",
        "image": "https://res.cloudinary.com/dj08db9y2/image/upload/profile_picture",
        "sameAs": [
          "https://linkedin.com/in/alqaba",
          "https://github.com/LedaThemis",
          "https://orcid.org/0009-0002-1924-5270",
          "https://scholar.google.com/citations?user=YQ10EnMAAAAJ"
        ]
      }
    </script>

    <SpeedInsights />
  </head>
  <body>
    <NavbarMinimal />
    <slot />
    <FooterMinimal />
    <style is:global>
      .external::after {
        background-color: grey;
        content: "";
        display: inline-flex;
        margin-left: 4px;
        mask-image: url(/assets/external.svg);
        mask-size: cover;
      }
    </style>
  </body>
  <script is:inline defer src="/_vercel/insights/script.js"></script>
</html>
